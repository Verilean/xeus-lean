   "source": [
    "import Sparkle\n",
    "open Sparkle.Core.Domain Sparkle.Core.Signal\n",
    "\n",
    "def counter4 : Signal defaultDomain (BitVec 4) :=\n",
    "  Signal.circuit do\n",
    "    let count \u2190 Signal.reg 0#4;\n",
    "    count <~ count + 1#4;\n",
    "    return count\n",
    "\n",
    "#eval! IO.println s!\"counter: {counter4.val 0}\"\n"
   ]
  }
 ],
